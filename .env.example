# Backend API Configuration
BASE_URL=http://localhost:3000/
API_VERSION=v1
API_BASE_URL=http://localhost:3000/

# App Configuration
APP_NAME=Family Academy
APP_VERSION=1.0.0
APP_ENVIRONMENT=production

# Security
ENCRYPTION_KEY=change_this_in_production
TOKEN_REFRESH_THRESHOLD_MINUTES=5
AUTO_REFRESH_ENABLED=true
SESSION_TIMEOUT_MINUTES=4320

# Firebase
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_API_KEY=your_api_key

# Networking
API_TIMEOUT_SECONDS=30
API_RETRY_COUNT=3
API_RETRY_DELAY_MS=1000
VALIDATE_TOKEN_ON_STARTUP=true
VALIDATE_TOKEN_INTERVAL_MINUTES=10

# Video Cache
MAX_CACHE_SIZE_MB=500
VIDEO_CACHE_DAYS=30

# Device
DEVICE_ID_PREFIX=FA_DEVICE_

# File Upload
MAX_FILE_UPLOAD_SIZE_MB=5

# Chatbot
CHATBOT_DAILY_LIMIT=10
